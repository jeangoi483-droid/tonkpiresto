<!DOCTYPE html>
<html>
<head>
    <title>TONKPIRESTO - Livraison de repas</title>
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#e67e22">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="TONKPIRESTO">
    <link rel="apple-touch-icon" href="/images/logo.png">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #f8f8f8;
            color: #1a1a1a;
            scroll-behavior: smooth;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 16px;
        }

        /* HEADER */
        .header {
            background: white;
            padding: 16px 0;
            border-bottom: 1px solid #f0f0f0;
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
        }

        .header-content {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo img {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            object-fit: cover;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .logo-text h1 {
            font-size: 22px;
            font-weight: 700;
            background: linear-gradient(135deg, #e67e22, #d35400);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            letter-spacing: -0.3px;
        }

        .logo-text p {
            font-size: 11px;
            color: #e67e22;
            font-weight: 500;
        }

        /* MENU UTILISATEUR */
        .user-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .btn-outline {
            background: transparent;
            border: 1px solid #e67e22;
            color: #e67e22;
            padding: 8px 18px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 14px;
            text-decoration: none;
            transition: all 0.2s;
        }

        .btn-outline:hover {
            background: #e67e22;
            color: white;
        }

        .btn-primary {
            background: #e67e22;
            color: white;
            padding: 8px 20px;
            border-radius: 40px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
            box-shadow: 0 2px 6px rgba(230,126,34,0.2);
        }

        .btn-primary:hover {
            background: #d35400;
            transform: translateY(-1px);
        }

        .cart-icon {
            background: #f5f5f5;
            padding: 8px 16px;
            border-radius: 40px;
            text-decoration: none;
            color: #333;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: background 0.2s;
        }

        .cart-icon:hover {
            background: #eaeaea;
        }

        /* RECHERCHE */
        .search-wrapper {
            margin: 32px 0 24px;
        }

        .search-bar {
            width: 100%;
            padding: 14px 20px;
            border-radius: 48px;
            border: 1px solid #e0e0e0;
            background: white;
            font-size: 16px;
            outline: none;
            transition: all 0.2s;
        }

        .search-bar:focus {
            border-color: #e67e22;
            box-shadow: 0 0 0 3px rgba(230,126,34,0.1);
        }

        /* CATÉGORIES */
        .categories {
            display: flex;
            gap: 12px;
            overflow-x: auto;
            padding-bottom: 12px;
            margin-bottom: 32px;
            scrollbar-width: thin;
        }

        .categories::-webkit-scrollbar {
            height: 4px;
        }

        .categorie-btn {
            background: white;
            border: 1px solid #eaeaea;
            padding: 8px 20px;
            border-radius: 40px;
            font-weight: 500;
            font-size: 14px;
            cursor: pointer;
            white-space: nowrap;
            transition: all 0.2s;
        }

        .categorie-btn.active {
            background: #e67e22;
            border-color: #e67e22;
            color: white;
        }

        /* GRILLE DES PLATS : 4 COLONNES sur tablette/desktop */
        .menu-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 24px;
            margin-bottom: 48px;
        }

        .plat-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 8px 20px rgba(0,0,0,0.05);
            transition: transform 0.2s, box-shadow 0.2s;
            display: flex;
            flex-direction: column;
        }

        .plat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 28px rgba(0,0,0,0.1);
        }

        .plat-image {
            width: 100%;
            height: 180px;
            object-fit: cover;
        }

        .plat-info {
            padding: 18px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .plat-nom {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .plat-description {
            font-size: 13px;
            color: #666;
            margin-bottom: 12px;
            line-height: 1.4;
        }

        .plat-prix {
            font-size: 20px;
            font-weight: 800;
            color: #e67e22;
            margin-bottom: 12px;
        }

        .plat-note {
            font-size: 13px;
            margin-bottom: 12px;
        }

        .etoiles {
            background: #fef5e8;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            display: inline-block;
        }

        .btn-avis {
            background: none;
            border: 1px solid #ddd;
            padding: 8px;
            border-radius: 30px;
            font-size: 12px;
            font-weight: 500;
            margin-bottom: 12px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-avis:hover {
            background: #f5f5f5;
        }

        .quantite-select {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 14px;
        }

        .quantite-select input {
            width: 65px;
            padding: 8px;
            border: 1px solid #ddd;
            border-radius: 30px;
            text-align: center;
        }

        .btn-ajouter {
            background: #e67e22;
            color: white;
            border: none;
            padding: 10px;
            border-radius: 40px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            transition: background 0.2s;
        }

        .btn-ajouter:hover {
            background: #d35400;
        }

        /* PIED DE PAGE AVEC LOGO */
        .footer {
            background: #1a1a2e;
            color: #ccc;
            padding: 40px 0 24px;
            margin-top: 40px;
            border-radius: 32px 32px 0 0;
        }

        .footer-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 32px;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 16px;
        }

        .footer-section h3 {
            color: #e67e22;
            margin-bottom: 16px;
            font-size: 18px;
        }

        .footer-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 16px;
        }

        .footer-logo img {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            object-fit: cover;
        }

        .footer-logo span {
            font-size: 18px;
            font-weight: 700;
            background: linear-gradient(135deg, #e67e22, #d35400);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }

        .footer-section p {
            margin-bottom: 8px;
            font-size: 14px;
        }

        .footer-section a {
            color: #ccc;
            text-decoration: none;
        }

        .footer-section a:hover {
            color: #e67e22;
        }

        .social-icons {
            display: flex;
            gap: 12px;
            margin-top: 12px;
        }

        .social-icons a {
            background: rgba(255,255,255,0.1);
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            transition: background 0.2s;
        }

        .social-icons a:hover {
            background: #e67e22;
        }

        .copyright {
            text-align: center;
            margin-top: 32px;
            padding-top: 20px;
            border-top: 1px solid #333;
            font-size: 12px;
        }

        /* MODAL */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }

        .modal-content {
            background: white;
            padding: 28px;
            border-radius: 32px;
            max-width: 400px;
            width: 90%;
        }

        .modal-buttons {
            display: flex;
            gap: 12px;
            margin-top: 20px;
        }

        .btn-confirm {
            background: #e67e22;
            color: white;
            border: none;
            padding: 12px;
            border-radius: 40px;
            flex: 1;
            cursor: pointer;
        }

        .btn-cancel {
            background: #ccc;
            border: none;
            padding: 12px;
            border-radius: 40px;
            flex: 1;
            cursor: pointer;
        }

        /* RESPONSIVE */
        @media (max-width: 1100px) {
            .menu-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @media (max-width: 800px) {
            .menu-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 550px) {
            .menu-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 700px) {
            .header-content {
                flex-direction: column;
                align-items: stretch;
            }

            .user-actions {
                justify-content: center;
                flex-wrap: wrap;
            }
        }
    </style>
</head>
<body>

<div class="header">
    <div class="container header-content">
        <div class="logo">
            <img src="/images/logo.png" alt="TONKPIRESTO">
            <div class="logo-text">
                <h1>TONKPIRESTO</h1>
                <p>Le goût des sommets, livré chez vous</p>
            </div>
        </div>

        <div class="user-actions">
            <% if (user && user.id) { %>
                <span style="font-weight: 500;">👋 <%= user.prenom %></span>
                <a href="/auth/profil" class="btn-outline">Mon profil</a>
                <a href="/auth/deconnexion" class="btn-outline">Déconnexion</a>
            <% } else { %>
                <a href="/auth/connexion" class="btn-outline">Connexion</a>
                <a href="/auth/inscription" class="btn-primary">Inscription</a>
            <% } %>
            <a href="/panier" class="cart-icon">🛒 Panier</a>
        </div>
    </div>
</div>

<div class="container">
    <div class="search-wrapper">
        <input type="text" id="searchInput" class="search-bar" placeholder="🔍 Rechercher un plat... (ex: pizza, burger, yassa...)" onkeyup="filterPlats()">
    </div>

    <div class="categories">
        <button class="categorie-btn <%= categorieActive === 'tous' ? 'active' : '' %>" onclick="filterCategorie('tous')">Tous</button>
        <button class="categorie-btn <%= categorieActive === 'entrees' ? 'active' : '' %>" onclick="filterCategorie('entrees')">🥗 Entrées</button>
        <button class="categorie-btn <%= categorieActive === 'plats' ? 'active' : '' %>" onclick="filterCategorie('plats')">🍝 Plats</button>
        <button class="categorie-btn <%= categorieActive === 'desserts' ? 'active' : '' %>" onclick="filterCategorie('desserts')">🍰 Desserts</button>
        <button class="categorie-btn <%= categorieActive === 'boissons' ? 'active' : '' %>" onclick="filterCategorie('boissons')">🥤 Boissons</button>
    </div>

    <div class="menu-grid" id="menuGrid">
        <% plats.forEach(plat => { %>
            <div class="plat-card" data-nom="<%= plat.nom.toLowerCase() %>" data-categorie="<%= plat.categorie %>">
                <img src="<%= plat.image %>" class="plat-image" alt="<%= plat.nom %>" onerror="this.src='https://placehold.co/400x200?text=Plat'">
                <div class="plat-info">
                    <div class="plat-nom"><%= plat.nom %></div>
                    <div class="plat-description"><%= plat.description %></div>
                    <div class="plat-prix"><%= plat.prix.toLocaleString() %> F CFA</div>
                    <div class="plat-note" id="note-<%= plat.id %>">⭐ Chargement...</div>
                    <button class="btn-avis" onclick="ouvrirModal(<%= plat.id %>, '<%= plat.nom.replace(/'/g, "\\'") %>')">⭐ Donner mon avis</button>
                    <form action="/ajouter-panier" method="POST">
                        <input type="hidden" name="id" value="<%= plat.id %>">
                        <div class="quantite-select">
                            <label>Quantité</label>
                            <input type="number" name="quantite" value="1" min="1" max="10">
                        </div>
                        <button type="submit" class="btn-ajouter">➕ Ajouter au panier</button>
                    </form>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<div class="footer">
    <div class="footer-container">
        <div class="footer-section">
            <div class="footer-logo">
                <img src="/images/logo.png" alt="TONKPIRESTO">
                <span>TONKPIRESTO</span>
            </div>
            <p>Le goût des sommets, livré chez vous</p>
            <p>Livraison rapide à Abidjan</p>
        </div>
        <div class="footer-section">
            <h3>📞 Contact</h3>
            <p>📱 <a href="tel:+2250555594062">+225 05 55 59 40 62</a></p>
            <p>📧 <a href="mailto:contact@tonkpiresto.com">contact@tonkpiresto.com</a></p>
            <p>🕒 11h - 22h (7j/7)</p>
        </div>
        <div class="footer-section">
            <h3>📍 Adresse</h3>
            <p>Abidjan, Côte d'Ivoire</p>
            <p>Livraison dans toute la ville</p>
            <div class="social-icons">
                <a href="#">📘</a>
                <a href="#">📸</a>
                <a href="#">🐦</a>
                <a href="#">💬</a>
            </div>
        </div>
    </div>
    <div class="copyright">
        © 2025 TONKPIRESTO — Tous droits réservés
    </div>
</div>

<!-- MODAL -->
<div id="modalAvis" class="modal">
    <div class="modal-content">
        <h3>⭐ Donner mon avis</h3>
        <form id="formAvis" method="POST">
            <select name="note" required style="width:100%; margin-bottom:12px; padding:10px;">
                <option value="5">⭐⭐⭐⭐⭐ Excellent</option>
                <option value="4">⭐⭐⭐⭐ Très bien</option>
                <option value="3">⭐⭐⭐ Bien</option>
                <option value="2">⭐⭐ Moyen</option>
                <option value="1">⭐ Décevant</option>
            </select>
            <textarea name="commentaire" rows="3" placeholder="Votre commentaire..." style="width:100%; margin-bottom:16px; padding:10px;"></textarea>
            <div class="modal-buttons">
                <button type="submit" class="btn-confirm">Envoyer</button>
                <button type="button" class="btn-cancel" onclick="fermerModal()">Annuler</button>
            </div>
        </form>
    </div>
</div>

<script>
    function filterCategorie(categorie) {
        window.location.href = '/?categorie=' + categorie;
    }

    function filterPlats() {
        const searchTerm = document.getElementById('searchInput').value.toLowerCase();
        const cards = document.querySelectorAll('.plat-card');
        cards.forEach(card => {
            const nom = card.getAttribute('data-nom');
            card.style.display = nom && nom.includes(searchTerm) ? '' : 'none';
        });
    }

    function ouvrirModal(platId, platNom) {
        const form = document.getElementById('formAvis');
        form.action = '/ajouter-avis/' + platId;
        document.getElementById('modalAvis').style.display = 'flex';
    }

    function fermerModal() {
        document.getElementById('modalAvis').style.display = 'none';
    }

    async function chargerNote(platId, elementId) {
        try {
            const res = await fetch('/api/avis/' + platId);
            const data = await res.json();
            const div = document.getElementById(elementId);
            if (div) {
                div.innerHTML = data.total > 0 ? `⭐ ${data.moyenne}/5 (${data.total} avis)` : '⭐ Pas encore d\'avis';
            }
        } catch(e) { console.error(e); }
    }

    window.onclick = function(e) {
        const modal = document.getElementById('modalAvis');
        if (e.target === modal) fermerModal();
    };

    document.addEventListener('DOMContentLoaded', () => {
        <% plats.forEach(plat => { %>
            chargerNote(<%= plat.id %>, 'note-<%= plat.id %>');
        <% }); %>
    });
</script>

</body>
</html>
