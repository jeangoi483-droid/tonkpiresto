<!DOCTYPE html>
<html>
<head>
    <title>TONKPIRESTO - Livraison de repas</title>
    <link rel="manifest" href="/manifest.json">
<meta name="theme-color" content="#e67e22">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="TONKPIRESTO">
<link rel="apple-touch-icon" href="/images/logo.png">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: url('https://i.pinimg.com/1200x/c3/c1/d8/c3c1d86a7345f85a2a1b44a0f47a1852.jpg?w=1920') no-repeat center center fixed;
            background-size: cover;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            padding: 20px;
            position: relative;
        }
        
        /* Overlay pour assombrir légèrement le fond et améliorer la lisibilité */
        body::before {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            z-index: -1;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            flex: 1;
        }
        
        .header {
            background: white;
            border-radius: 15px;
            padding: 15px 20px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }
        
        /* STYLE DU LOGO AVEC IMAGE */
        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .logo-image {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: 50%;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
        
        .logo-nom {
            font-size: 24px;
            font-weight: bold;
            background: linear-gradient(135deg, #e67e22, #d35400);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: 1px;
        }
        
        .logo-slogan {
            font-size: 10px;
            color: #e67e22;
            margin-top: 2px;
            letter-spacing: 0.5px;
        }
        
        /* MENU CENTRAL (Connexion et Inscription) */
        .center-menu {
            flex: 1;
            text-align: center;
        }
        
        .user-menu-center {
            display: inline-flex;
            align-items: center;
            gap: 15px;
            background: #fef5e8;
            padding: 8px 20px;
            border-radius: 50px;
        }
        
        .user-name {
            color: #e67e22;
            font-weight: bold;
            background: white;
            padding: 6px 15px;
            border-radius: 25px;
            font-size: 14px;
        }
        
        .btn-connexion, .btn-inscription, .btn-deconnexion {
            padding: 6px 18px;
            border-radius: 25px;
            text-decoration: none;
            transition: all 0.3s;
            font-weight: bold;
            font-size: 14px;
            display: inline-block;
        }
        
        .btn-connexion {
            background: #e67e22;
            color: white;
        }
        
        .btn-inscription {
            background: #27ae60;
            color: white;
        }
        
        .btn-deconnexion {
            background: #e74c3c;
            color: white;
        }
        
        .btn-connexion:hover, .btn-inscription:hover, .btn-deconnexion:hover {
            transform: scale(1.05);
        }
        
        /* PANIER À DROITE */
        .btn-panier {
            background: linear-gradient(135deg, #e67e22, #d35400);
            color: white;
            padding: 10px 25px;
            border-radius: 25px;
            text-decoration: none;
            font-weight: bold;
            font-size: 14px;
            white-space: nowrap;
        }
        
        .btn-panier:hover {
            transform: scale(1.05);
        }
        
        .search-bar {
            background: white;
            border-radius: 50px;
            padding: 10px 20px;
            margin-bottom: 25px;
            display: flex;
            gap: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        
        .search-bar input {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 25px;
            background: #f5f5f5;
            font-size: 16px;
        }
        
        .search-bar input:focus {
            outline: none;
            background: #eee;
        }
        
        .categories {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 30px;
            justify-content: center;
        }
        
        .categorie-btn {
            background: white;
            border: none;
            padding: 10px 25px;
            border-radius: 25px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s;
            color: #666;
        }
        
        .categorie-btn.active {
            background: linear-gradient(135deg, #e67e22, #d35400);
            color: white;
            transform: scale(1.05);
        }
        
        .categorie-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        
        /* GRILLE : 3 PRODUITS PAR LIGNE */
        .menu-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 25px;
            animation: fadeIn 0.5s ease;
        }
        
        @media (min-width: 1400px) {
            .menu-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }
        
        @media (max-width: 900px) {
            .menu-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        
        @media (max-width: 600px) {
            .menu-grid {
                grid-template-columns: 1fr;
            }
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .plat-card {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
        }
        
        .plat-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }
        
        .plat-image {
            width: 100%;
            height: 200px;
            object-fit: cover;
            transition: transform 0.3s;
        }
        
        .plat-card:hover .plat-image {
            transform: scale(1.05);
        }
        
        .plat-info {
            padding: 20px;
        }
        
        .plat-nom {
            font-size: 18px;
            font-weight: bold;
            color: #e67e22;
            margin-bottom: 8px;
        }
        
        .plat-description {
            font-size: 13px;
            color: #666;
            margin-bottom: 10px;
            line-height: 1.4;
        }
        
        .plat-prix {
            font-size: 20px;
            font-weight: bold;
            color: #27ae60;
            margin-bottom: 12px;
        }
        
        .plat-note {
            margin: 8px 0;
            font-size: 13px;
        }
        
        .etoiles {
            background: #fef5e8;
            padding: 4px 10px;
            border-radius: 20px;
            display: inline-block;
            color: #f39c12;
            font-size: 12px;
        }
        
        .btn-avis {
            background: #3498db;
            color: white;
            border: none;
            padding: 7px 12px;
            border-radius: 20px;
            cursor: pointer;
            font-size: 11px;
            margin-top: 8px;
            width: 100%;
        }
        
        .btn-avis:hover {
            background: #2980b9;
        }
        
        .quantite-select {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 10px 0;
        }
        
        .quantite-select label {
            font-size: 13px;
            color: #666;
        }
        
        .quantite-select input {
            width: 55px;
            padding: 6px;
            border: 1px solid #ddd;
            border-radius: 8px;
            text-align: center;
        }
        
        .btn-ajouter {
            width: 100%;
            background: linear-gradient(135deg, #e67e22, #d35400);
            color: white;
            border: none;
            padding: 10px;
            border-radius: 25px;
            cursor: pointer;
            font-size: 14px;
            font-weight: bold;
            transition: all 0.3s;
        }
        
        .btn-ajouter:hover {
            transform: scale(1.02);
            box-shadow: 0 5px 15px rgba(230,126,34,0.4);
        }
        
        .no-results {
            text-align: center;
            padding: 50px;
            background: white;
            border-radius: 15px;
            color: #666;
        }
        
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }
        
        .modal-content {
            background: white;
            padding: 25px;
            border-radius: 20px;
            max-width: 400px;
            width: 90%;
            margin: auto;
        }
        
        .modal-content h3 {
            color: #e67e22;
            margin-bottom: 15px;
            text-align: center;
        }
        
        .modal-content select, .modal-content textarea {
            width: 100%;
            padding: 10px;
            margin: 8px 0;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
        }
        
        .modal-buttons {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }
        
        .modal-buttons button {
            flex: 1;
            padding: 10px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
        }
        
        .btn-submit-avis {
            background: #e67e22;
            color: white;
        }
        
        .btn-cancel-avis {
            background: #95a5a6;
            color: white;
        }
        
        /* ========== PIED DE PAGE ========== */
        .footer {
            background: #1a1a2e;
            color: white;
            margin-top: 50px;
            padding: 30px 20px 20px;
            border-radius: 20px 20px 0 0;
        }
        
        .footer-container {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
        }
        
        .footer-section h3 {
            color: #e67e22;
            margin-bottom: 15px;
            font-size: 18px;
        }
        
        .footer-section p {
            margin-bottom: 8px;
            color: #ccc;
            font-size: 14px;
        }
        
        .footer-section a {
            color: #e67e22;
            text-decoration: none;
        }
        
        .footer-section a:hover {
            text-decoration: underline;
        }
        
        .social-icons {
            display: flex;
            gap: 15px;
            margin-top: 15px;
        }
        
        .social-icons a {
            background: #e67e22;
            width: 35px;
            height: 35px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-size: 18px;
        }
        
        .copyright {
            text-align: center;
            padding-top: 20px;
            margin-top: 20px;
            border-top: 1px solid #333;
            font-size: 12px;
            color: #888;
        }
        
        /* Nouveau style pour le bouton profil */
        .btn-profil {
            background: #3498db;
            color: white;
            padding: 6px 18px;
            border-radius: 25px;
            text-decoration: none;
            font-weight: bold;
            font-size: 14px;
        }

        .btn-profil:hover {
            background: #2980b9;
            transform: scale(1.05);
        }
        
        @media (max-width: 768px) {
            .header {
                flex-direction: column;
                text-align: center;
            }
            .center-menu {
                width: 100%;
            }
            .categories {
                gap: 8px;
            }
            .categorie-btn {
                padding: 6px 15px;
                font-size: 12px;
            }
            .logo-image {
                width: 50px;
                height: 50px;
            }
            .logo-nom {
                font-size: 18px;
            }
            .footer-container {
                grid-template-columns: 1fr;
                text-align: center;
            }
            .social-icons {
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
    <!-- LOGO À GAUCHE AVEC IMAGE -->
    <div class="logo">
        <img src="/images/logo.png" alt="TONKPIRESTO" class="logo-image" onerror="this.src='https://placehold.co/60x60?text=🍕'">
        <div>
            <div class="logo-nom">TONKPIRESTO</div>
            <div class="logo-slogan">LE GOUT DES SOMMETS, LIVRE CHEZ VOUS</div>
        </div>
    </div>
    
    <!-- MENU CENTRAL : CONNEXION / INSCRIPTION -->
    <div class="user-menu-center">
        <% if (user && user.id) { %>
            <span class="user-name">👋 Bonjour <%= user.prenom %> <%= user.nom %></span>
            <a href="/auth/profil" class="btn-profil">👤 Mon profil</a>
            <a href="/auth/deconnexion" class="btn-deconnexion">🚪 Déconnexion</a>
        <% } else { %>
            <a href="/auth/connexion" class="btn-connexion">🔑 Connexion</a>
            <a href="/auth/inscription" class="btn-inscription">📝 Inscription</a>
        <% } %>
    </div>
    
    <!-- PANIER À DROITE -->
    <a href="/panier" class="btn-panier">📦 Voir mon panier</a>
</div>
        
        <div class="search-bar">
            <input type="text" id="searchInput" placeholder="🔍 Rechercher un plat..." onkeyup="filterPlats()">
        </div>
        
        <div class="categories">
            <button class="categorie-btn <%= categorieActive === 'tous' ? 'active' : '' %>" onclick="filterCategorie('tous')">Tous</button>
            <button class="categorie-btn <%= categorieActive === 'entrees' ? 'active' : '' %>" onclick="filterCategorie('entrees')">🥗 Entrées</button>
            <button class="categorie-btn <%= categorieActive === 'plats' ? 'active' : '' %>" onclick="filterCategorie('plats')">🍝 Plats</button>
            <button class="categorie-btn <%= categorieActive === 'desserts' ? 'active' : '' %>" onclick="filterCategorie('desserts')">🍰 Desserts</button>
            <button class="categorie-btn <%= categorieActive === 'boissons' ? 'active' : '' %>" onclick="filterCategorie('boissons')">🥤 Boissons</button>
        </div>
        
        <div class="menu-grid" id="menuGrid">
            <% plats.forEach(plat => { %>
                <div class="plat-card" data-nom="<%= plat.nom.toLowerCase() %>" data-categorie="<%= plat.categorie %>" data-id="<%= plat.id %>">
                    <img src="<%= plat.image %>" alt="<%= plat.nom %>" class="plat-image" onerror="this.src='https://placehold.co/300x200?text=Plat'">
                    <div class="plat-info">
                        <div class="plat-nom"><%= plat.nom %></div>
                        <div class="plat-description"><%= plat.description %></div>
                        <div class="plat-prix"><%= plat.prix.toLocaleString() %> F CFA</div>
                        
                        <div class="plat-note" id="note-<%= plat.id %>">
                            <span class="etoiles">⭐ Chargement...</span>
                        </div>
                        
                        <button type="button" class="btn-avis" onclick="ouvrirModal(<%= plat.id %>, '<%= plat.nom.replace(/'/g, "\\'") %>')">
                            ⭐ Donner mon avis
                        </button>
                        
                        <form action="/ajouter-panier" method="POST">
                            <input type="hidden" name="id" value="<%= plat.id %>">
                            <div class="quantite-select">
                                <label>Quantité :</label>
                                <input type="number" name="quantite" value="1" min="1" max="10">
                            </div>
                            <button type="submit" class="btn-ajouter">➕ Ajouter au panier</button>
                        </form>
                    </div>
                </div>
            <% }) %>
        </div>
        
        <% if (plats.length === 0) { %>
            <div class="no-results">
                <p>😕 Aucun plat trouvé</p>
            </div>
        <% } %>
    </div>
    
    <!-- ========== PIED DE PAGE ========== -->
    <div class="footer">
        <div class="footer-container">
            <div class="footer-section">
                <h3>🍕 TONKPIRESTO</h3>
                <p>LE GOUT DES SOMMETS, LIVRE CHEZ VOUS</p>
                <p>Votre service de livraison de repas préféré.</p>
            </div>
            <div class="footer-section">
                <h3>📞 CONTACT</h3>
                <p>📱 Téléphone : <a href="tel:+2250555594062">+225 05 55 59 40 62</a></p>
                <p>📧 Email : <a href="mailto:contact@tonkpiresto.com">contact@tonkpiresto.com</a></p>
                <p>🕒 Horaires : 11h00 - 22h00 (7j/7)</p>
            </div>
            <div class="footer-section">
                <h3>📍 ADRESSE</h3>
                <p>Abidjan, Côte d'Ivoire</p>
                <p>Livraison dans tout Abidjan</p>
                <div class="social-icons">
                    <a href="#" style="color: white;">📘</a>
                    <a href="#" style="color: white;">📸</a>
                    <a href="#" style="color: white;">🐦</a>
                    <a href="#" style="color: white;">💬</a>
                </div>
            </div>
        </div>
        <div class="copyright">
            &copy; 2024 TONKPIRESTO - Tous droits réservés | Site réalisé avec 🍕 pour vous servir
        </div>
    </div>
    
    <div id="modalAvis" class="modal">
        <div class="modal-content">
            <h3>⭐ Donner mon avis</h3>
            <form id="formAvis" method="POST">
                <div>
                    <select name="note" required>
                        <option value="5">⭐⭐⭐⭐⭐ 5/5 - Excellent</option>
                        <option value="4">⭐⭐⭐⭐ 4/5 - Très bien</option>
                        <option value="3">⭐⭐⭐ 3/5 - Bien</option>
                        <option value="2">⭐⭐ 2/5 - Moyen</option>
                        <option value="1">⭐ 1/5 - Décevant</option>
                    </select>
                </div>
                <div>
                    <textarea name="commentaire" placeholder="Votre commentaire..." rows="3" required></textarea>
                </div>
                <div class="modal-buttons">
                    <button type="submit" class="btn-submit-avis">📝 Envoyer</button>
                    <button type="button" class="btn-cancel-avis" onclick="fermerModal()">❌ Annuler</button>
                </div>
            </form>
        </div>
    </div>
    
    <script>
        function filterCategorie(categorie) {
            window.location.href = '/?categorie=' + categorie;
        }
        
        function filterPlats() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const cards = document.querySelectorAll('.plat-card');
            cards.forEach(card => {
                const nom = card.getAttribute('data-nom');
                if (nom && nom.includes(searchTerm)) {
                    card.style.display = '';
                } else {
                    card.style.display = 'none';
                }
            });
        }
        
        function ouvrirModal(platId, platNom) {
            const form = document.getElementById('formAvis');
            if (form) {
                form.action = '/ajouter-avis/' + platId;
            }
            document.getElementById('modalAvis').style.display = 'flex';
        }
        
        function fermerModal() {
            document.getElementById('modalAvis').style.display = 'none';
        }
        
        async function chargerNote(platId, elementId) {
            try {
                const response = await fetch('/api/avis/' + platId);
                const data = await response.json();
                const noteDiv = document.getElementById(elementId);
                if (noteDiv && data) {
                    if (data.total > 0) {
                        noteDiv.innerHTML = '<span class="etoiles">⭐ ' + data.moyenne + '/5 (' + data.total + ' avis)</span>';
                    } else {
                        noteDiv.innerHTML = '<span class="etoiles">⭐ Pas encore d\'avis</span>';
                    }
                }
            } catch (error) {
                console.error('Erreur:', error);
            }
        }
        
        window.onclick = function(event) {
            const modal = document.getElementById('modalAvis');
            if (event.target === modal) {
                fermerModal();
            }
        }
        
        document.addEventListener('DOMContentLoaded', function() {
            <% plats.forEach(plat => { %>
                chargerNote(<%= plat.id %>, 'note-<%= plat.id %>');
            <% }); %>
        });
    </script>
<script>
    if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js')
            .then(reg => console.log('✅ Service Worker enregistré', reg))
            .catch(err => console.error('❌ Erreur Service Worker', err));
    }
</script>

</body>
</html>