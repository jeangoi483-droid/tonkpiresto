<!DOCTYPE html>
<html>
<head>
    <title>TONKPIRESTO - Livraison de repas</title>
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#e67e22">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="TONKPIRESTO">
    <link rel="apple-touch-icon" href="/images/logo.png">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #fff5eb 0%, #ffe4d6 100%);
            color: #1a1a1a;
        }
        .container { max-width: 1200px; margin: 0 auto; padding: 0 16px; }
        .header {
            background: white;
            padding: 16px 0;
            border-bottom: 1px solid #f0f0f0;
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(10px);
        }
        .header-content { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
        .logo { display: flex; align-items: center; gap: 12px; }
        .logo img { width: 48px; height: 48px; border-radius: 50%; object-fit: cover; }
        .logo-text h1 {
            font-size: 22px;
            font-weight: 700;
            background: linear-gradient(135deg, #e67e22, #d35400);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }
        .user-actions { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
        .btn-outline {
            background: transparent;
            border: 1px solid #e67e22;
            color: #e67e22;
            padding: 8px 18px;
            border-radius: 40px;
            font-weight: 600;
            text-decoration: none;
            transition: 0.2s;
        }
        .btn-outline:hover { background: #e67e22; color: white; }
        .btn-primary {
            background: #e67e22;
            color: white;
            padding: 8px 20px;
            border-radius: 40px;
            font-weight: 600;
            text-decoration: none;
        }
        .cart-icon {
            background: #f5f5f5;
            padding: 8px 16px;
            border-radius: 40px;
            text-decoration: none;
            color: #333;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .cart-count {
            background: #e67e22;
            color: white;
            border-radius: 30px;
            padding: 2px 8px;
            font-size: 12px;
        }
        .search-bar {
            width: 100%;
            padding: 14px 20px;
            border-radius: 48px;
            border: 1px solid #e0e0e0;
            background: white;
            margin: 32px 0 24px;
            font-size: 16px;
        }
        .categories {
            display: flex;
            gap: 12px;
            overflow-x: auto;
            margin-bottom: 32px;
            padding-bottom: 12px;
        }
        .categorie-btn {
            background: white;
            border: 1px solid #eaeaea;
            padding: 8px 20px;
            border-radius: 40px;
            font-weight: 500;
            cursor: pointer;
            white-space: nowrap;
        }
        .categorie-btn.active { background: #e67e22; border-color: #e67e22; color: white; }
        .menu-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 24px;
            margin-bottom: 48px;
        }
        .plat-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 8px 20px rgba(0,0,0,0.05);
            transition: 0.2s;
        }
        .plat-card:hover { transform: translateY(-4px); box-shadow: 0 12px 28px rgba(0,0,0,0.1); }
        .plat-image { width: 100%; height: 180px; object-fit: cover; }
        .plat-info { padding: 18px; }
        .plat-nom { font-size: 18px; font-weight: 700; margin-bottom: 6px; }
        .plat-description { font-size: 13px; color: #666; margin-bottom: 12px; }
        .plat-prix { font-size: 20px; font-weight: 800; color: #e67e22; margin-bottom: 12px; }
        .plat-note { margin-bottom: 12px; font-size: 13px; }
        .etoiles {
            background: #fef5e8;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            display: inline-block;
        }
        .btn-avis {
            background: none;
            border: 1px solid #ddd;
            padding: 8px;
            border-radius: 30px;
            font-size: 12px;
            font-weight: 500;
            margin-bottom: 12px;
            cursor: pointer;
            width: 100%;
        }
        .quantite-select { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
        .quantite-select input {
            width: 65px;
            padding: 8px;
            border: 1px solid #ddd;
            border-radius: 30px;
            text-align: center;
        }
        .btn-ajouter {
            background: #e67e22;
            color: white;
            border: none;
            padding: 10px;
            border-radius: 40px;
            font-weight: 700;
            cursor: pointer;
            width: 100%;
        }
        .footer {
            background: #1a1a2e;
            color: #ccc;
            padding: 40px 0 24px;
            margin-top: 40px;
            border-radius: 32px 32px 0 0;
        }
        .footer-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 32px;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 16px;
        }
        .footer-logo { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
        .footer-logo img { width: 45px; height: 45px; border-radius: 50%; }
        .copyright {
            text-align: center;
            margin-top: 32px;
            padding-top: 20px;
            border-top: 1px solid #333;
            font-size: 12px;
        }
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }
        .modal-content {
            background: white;
            padding: 28px;
            border-radius: 32px;
            max-width: 400px;
            width: 90%;
        }
        .modal-buttons { display: flex; gap: 12px; margin-top: 20px; }
        .btn-confirm { background: #e67e22; color: white; border: none; padding: 12px; border-radius: 40px; flex: 1; cursor: pointer; }
        .btn-cancel { background: #ccc; border: none; padding: 12px; border-radius: 40px; flex: 1; cursor: pointer; }
        @media (max-width: 1100px) { .menu-grid { grid-template-columns: repeat(3, 1fr); } }
        @media (max-width: 800px) { .menu-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 550px) { .menu-grid { grid-template-columns: 1fr; } }
        @media (max-width: 700px) {
            .header-content { flex-direction: column; align-items: stretch; }
            .user-actions { justify-content: center; }
        }
    </style>
</head>
<body>

<div class="header">
    <div class="container header-content">
        <div class="logo">
            <img src="/images/logo.png" alt="TONKPIRESTO">
            <div class="logo-text"><h1>TONKPIRESTO</h1></div>
        </div>
        <div class="user-actions">
            <% if (user && user.id) { %>
                <span>👋 <%= user.prenom %></span>
                <a href="/auth/profil" class="btn-outline">Mon profil</a>
                <a href="/auth/deconnexion" class="btn-outline">Déconnexion</a>
            <% } else { %>
                <a href="/auth/connexion" class="btn-outline">Connexion</a>
                <a href="/auth/inscription" class="btn-primary">Inscription</a>
            <% } %>
            <a href="/panier" class="cart-icon" id="cartLink">
                🛒 Panier
                <span id="cartCount" class="cart-count">0</span>
            </a>
        </div>
    </div>
</div>

<div class="container">
    <input type="text" id="searchInput" class="search-bar" placeholder="🔍 Rechercher un plat..." onkeyup="filterPlats()">

    <div class="categories">
        <button class="categorie-btn <%= categorieActive === 'tous' ? 'active' : '' %>" onclick="filterCategorie('tous')">Tous</button>
        <button class="categorie-btn <%= categorieActive === 'entrees' ? 'active' : '' %>" onclick="filterCategorie('entrees')">🥗 Entrées</button>
        <button class="categorie-btn <%= categorieActive === 'plats' ? 'active' : '' %>" onclick="filterCategorie('plats')">🍝 Plats</button>
        <button class="categorie-btn <%= categorieActive === 'desserts' ? 'active' : '' %>" onclick="filterCategorie('desserts')">🍰 Desserts</button>
        <button class="categorie-btn <%= categorieActive === 'boissons' ? 'active' : '' %>" onclick="filterCategorie('boissons')">🥤 Boissons</button>
    </div>

    <div class="menu-grid" id="menuGrid">
        <% plats.forEach(plat => { %>
            <div class="plat-card" data-nom="<%= plat.nom.toLowerCase() %>" data-id="<%= plat.id %>">
                <img src="<%= plat.image %>" class="plat-image" alt="<%= plat.nom %>" onerror="this.src='https://placehold.co/400x200?text=Plat'">
                <div class="plat-info">
                    <div class="plat-nom"><%= plat.nom %></div>
                    <div class="plat-description"><%= plat.description %></div>
                    <div class="plat-prix"><%= plat.prix.toLocaleString() %> F CFA</div>
                    <div class="plat-note" id="note-<%= plat.id %>">⭐ Chargement...</div>
                    <button class="btn-avis" onclick="ouvrirModal(<%= plat.id %>, '<%= plat.nom.replace(/'/g, "\\'") %>')">⭐ Donner mon avis</button>
                    <div class="quantite-select">
                        <label>Quantité</label>
                        <input type="number" id="qty-<%= plat.id %>" value="1" min="1" max="10">
                    </div>
                    <button class="btn-ajouter" data-id="<%= plat.id %>">➕ Ajouter au panier</button>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<div class="footer">
    <div class="footer-container">
        <div class="footer-section">
            <div class="footer-logo">
                <img src="/images/logo.png" alt="TONKPIRESTO">
                <span>TONKPIRESTO</span>
            </div>
            <p>Livraison rapide à Abidjan</p>
        </div>
        <div class="footer-section">
            <h3>📞 Contact</h3>
            <p>📱 <a href="tel:+2250555594062">+225 05 55 59 40 62</a></p>
            <p>📧 contact@tonkpiresto.com</p>
        </div>
    </div>
    <div class="copyright">© 2025 TONKPIRESTO</div>
</div>

<div id="modalAvis" class="modal">
    <div class="modal-content">
        <h3>⭐ Donner mon avis</h3>
        <form id="formAvis" method="POST">
            <select name="note" required style="width:100%; margin-bottom:12px; padding:10px;">
                <option value="5">⭐⭐⭐⭐⭐ Excellent</option>
                <option value="4">⭐⭐⭐⭐ Très bien</option>
                <option value="3">⭐⭐⭐ Bien</option>
                <option value="2">⭐⭐ Moyen</option>
                <option value="1">⭐ Décevant</option>
            </select>
            <textarea name="commentaire" rows="3" placeholder="Votre commentaire..." style="width:100%; margin-bottom:16px; padding:10px;"></textarea>
            <div class="modal-buttons">
                <button type="submit" class="btn-confirm">Envoyer</button>
                <button type="button" class="btn-cancel" onclick="fermerModal()">Annuler</button>
            </div>
        </form>
    </div>
</div>

<script>
    function filterCategorie(categorie) {
        window.location.href = '/?categorie=' + categorie;
    }

    function filterPlats() {
        const searchTerm = document.getElementById('searchInput').value.toLowerCase();
        document.querySelectorAll('.plat-card').forEach(card => {
            const nom = card.getAttribute('data-nom');
            card.style.display = nom && nom.includes(searchTerm) ? '' : 'none';
        });
    }

    function ouvrirModal(platId) {
        document.getElementById('formAvis').action = '/ajouter-avis/' + platId;
        document.getElementById('modalAvis').style.display = 'flex';
    }

    function fermerModal() {
        document.getElementById('modalAvis').style.display = 'none';
    }

    async function chargerNote(platId, elementId) {
        try {
            const res = await fetch('/api/avis/' + platId);
            const data = await res.json();
            const div = document.getElementById(elementId);
            if (div) {
                div.innerHTML = data.total > 0 ? `⭐ ${data.moyenne}/5 (${data.total} avis)` : '⭐ Pas encore d\'avis';
            }
        } catch(e) {}
    }

    function updateCartCount() {
        fetch('/api/cart-count')
            .then(res => res.json())
            .then(data => {
                const badge = document.getElementById('cartCount');
                if (badge) badge.innerText = data.count;
            })
            .catch(err => console.log(err));
    }

    // AJOUT AU PANIER EN AJAX (sans rechargement)
    document.querySelectorAll('.btn-ajouter').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            const platId = this.getAttribute('data-id');
            const quantite = document.getElementById('qty-' + platId).value;

            fetch('/ajouter-panier', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ id: platId, quantite: quantite })
            })
            .then(response => {
                if (response.ok) {
                    updateCartCount();  // Met à jour le badge
                    // Petit effet visuel (optionnel)
                    btn.textContent = '✅ Ajouté !';
                    setTimeout(() => { btn.textContent = '➕ Ajouter au panier'; }, 1000);
                } else {
                    alert('Erreur lors de l\'ajout');
                }
            })
            .catch(err => console.error('Erreur:', err));
        });
    });

    window.onclick = function(e) {
        const modal = document.getElementById('modalAvis');
        if (e.target === modal) fermerModal();
    };

    document.addEventListener('DOMContentLoaded', () => {
        <% plats.forEach(plat => { %>
            chargerNote(<%= plat.id %>, 'note-<%= plat.id %>');
        <% }); %>
        updateCartCount();
        setInterval(updateCartCount, 3000);
    });
</script>
</body>
</html>
