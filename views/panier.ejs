<!DOCTYPE html>
<html>
<head>
    <title>TONKPIRESTO - Mon panier</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        
        .container {
            max-width: 1000px;
            margin: 0 auto;
        }
        
        .header {
            background: white;
            border-radius: 15px;
            padding: 15px 20px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }
        
        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .logo-image {
            width: 55px;
            height: 55px;
            object-fit: cover;
            border-radius: 50%;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
        
        .logo-nom {
            font-size: 20px;
            font-weight: bold;
            background: linear-gradient(135deg, #e67e22, #d35400);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        
        .logo-slogan {
            font-size: 9px;
            color: #e67e22;
            margin-top: 2px;
        }
        
        .retour-btn {
            background: #666;
            color: white;
            padding: 10px 20px;
            border-radius: 25px;
            text-decoration: none;
        }
        
        .panier-vide {
            text-align: center;
            padding: 60px;
            background: white;
            border-radius: 15px;
        }
        
        .panier-vide button {
            margin-top: 20px;
            background: #e67e22;
            border: none;
            padding: 12px 30px;
            border-radius: 25px;
            color: white;
            cursor: pointer;
        }
        
        .article-card {
            background: white;
            border-radius: 15px;
            padding: 15px;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 15px;
            flex-wrap: wrap;
            transition: all 0.3s;
        }
        
        .article-card:hover {
            transform: translateX(5px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        
        .article-image {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 10px;
        }
        
        .article-details {
            flex: 2;
        }
        
        .article-nom {
            font-weight: bold;
            font-size: 18px;
            color: #e67e22;
        }
        
        .article-desc {
            font-size: 12px;
            color: #666;
        }
        
        .article-prix {
            font-weight: bold;
            color: #27ae60;
        }
        
        .quantite-control {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .quantite-control input {
            width: 60px;
            padding: 8px;
            border: 1px solid #ddd;
            border-radius: 8px;
            text-align: center;
        }
        
        .btn-retirer {
            background: #e74c3c;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 8px;
            cursor: pointer;
        }
        
        .total {
            background: white;
            border-radius: 15px;
            padding: 20px;
            margin-top: 20px;
            text-align: right;
            font-size: 24px;
            font-weight: bold;
            color: #e67e22;
        }
        
        .form-livraison {
            background: white;
            border-radius: 15px;
            padding: 25px;
            margin-top: 20px;
        }
        
        .form-livraison h2 {
            margin-bottom: 20px;
            color: #333;
        }
        
        input, textarea {
            width: 100%;
            padding: 12px;
            margin: 10px 0;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
        }
        
        .btn-valider {
            width: 100%;
            background: linear-gradient(135deg, #27ae60, #219a52);
            color: white;
            border: none;
            padding: 15px;
            border-radius: 25px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 15px;
        }
        
        .btn-paiement-ligne {
            width: 100%;
            background: linear-gradient(135deg, #635bff, #4a42c4);
            color: white;
            border: none;
            padding: 15px;
            border-radius: 25px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 10px;
        }
        
        .separateur {
            text-align: center;
            margin: 20px 0;
            position: relative;
        }
        
        .separateur::before,
        .separateur::after {
            content: "";
            position: absolute;
            top: 50%;
            width: 45%;
            height: 1px;
            background: #ddd;
        }
        
        .separateur::before {
            left: 0;
        }
        
        .separateur::after {
            right: 0;
        }
        
        .separateur span {
            background: white;
            padding: 0 10px;
            color: #999;
        }
        
        /* ========== STYLE WAVE ========== */
        .wave-section {
            background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
            border-radius: 15px;
            padding: 20px;
            margin-top: 20px;
            text-align: center;
            border: 2px solid #4caf50;
        }
        
        .wave-logo {
            width: 60px;
            height: 60px;
            margin: 0 auto 10px;
            object-fit: contain;
        }
        
        .wave-number {
            background: white;
            padding: 12px;
            border-radius: 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 15px 0;
            font-size: 20px;
        }
        
        .btn-copier {
            background: #4caf50;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 25px;
            cursor: pointer;
        }
        
        .btn-wave {
            background: #4caf50;
            color: white;
            border: none;
            padding: 12px;
            border-radius: 25px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 15px;
            width: 100%;
        }
        
        .btn-wave:hover {
            background: #388e3c;
        }
        
        .wave-instruction {
            font-size: 12px;
            color: #555;
            margin: 10px 0;
        }
        
        .footer {
            background: #1a1a2e;
            color: white;
            margin-top: 50px;
            padding: 30px 20px 20px;
            border-radius: 20px 20px 0 0;
        }
        
        .footer-container {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
        }
        
        .footer-section h3 {
            color: #e67e22;
            margin-bottom: 15px;
            font-size: 18px;
        }
        
        .footer-section p {
            margin-bottom: 8px;
            color: #ccc;
            font-size: 14px;
        }
        
        .footer-section a {
            color: #e67e22;
            text-decoration: none;
        }
        
        .footer-section a:hover {
            text-decoration: underline;
        }
        
        .social-icons {
            display: flex;
            gap: 15px;
            margin-top: 15px;
        }
        
        .social-icons a {
            background: #e67e22;
            width: 35px;
            height: 35px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-size: 18px;
        }
        
        .copyright {
            text-align: center;
            padding-top: 20px;
            margin-top: 20px;
            border-top: 1px solid #333;
            font-size: 12px;
            color: #888;
        }
        
        @media (max-width: 768px) {
            .article-card {
                flex-direction: column;
                text-align: center;
            }
            .total {
                text-align: center;
            }
            .logo-image {
                width: 45px;
                height: 45px;
            }
            .logo-nom {
                font-size: 16px;
            }
            .footer-container {
                grid-template-columns: 1fr;
                text-align: center;
            }
            .social-icons {
                justify-content: center;
            }
            .wave-number {
                font-size: 16px;
                flex-wrap: wrap;
                gap: 10px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="logo">
                <img src="/images/logo.jpg" alt="TONKPIRESTO" class="logo-image" onerror="this.src='https://placehold.co/55x55?text=🍕'">
                <div>
                    <div class="logo-nom">TONKPIRESTO</div>
                    <div class="logo-slogan">LE GOUT DES SOMMETS, LIVRE CHEZ VOUS</div>
                </div>
            </div>
            <a href="/" class="retour-btn">← Retour au menu</a>
        </div>
        
        <% if (articles.length === 0) { %>
            <div class="panier-vide">
                <p>🍕 Votre panier est vide.</p>
                <a href="/"><button>Voir le menu</button></a>
            </div>
        <% } else { %>
            
            <% articles.forEach(article => { %>
                <div class="article-card">
                    <img src="<%= article.image %>" class="article-image" onerror="this.src='https://placehold.co/80x80?text=Plat'">
                    <div class="article-details">
                        <div class="article-nom"><%= article.nom %></div>
                        <div class="article-desc"><%= article.description %></div>
                        <div class="article-prix"><%= article.prix.toLocaleString() %> F CFA / unité</div>
                    </div>
                    <form action="/panier/modifier-quantite/<%= article.id %>" method="POST" class="quantite-control">
                        <input type="number" name="quantite" value="<%= article.quantite %>" min="0" max="10" onchange="this.form.submit()">
                    </form>
                    <div style="min-width: 100px; text-align: center;">
                        <strong><%= article.total.toLocaleString() %> F CFA</strong>
                    </div>
                    <form action="/panier/retirer/<%= article.id %>" method="POST">
                        <button type="submit" class="btn-retirer">❌ Retirer</button>
                    </form>
                </div>
            <% }) %>
            
            <div class="total">
                Total : <%= total.toLocaleString() %> F CFA
            </div>
            
            <div class="form-livraison">
                <h2>📝 Informations de livraison</h2>
                <form action="/valider-commande" method="POST">
                    <div>
                        <input type="tel" name="telephone" required placeholder="📞 Votre numéro de téléphone">
                    </div>
                    <div>
                        <textarea name="adresse" required placeholder="🏠 Votre adresse complète" rows="3"></textarea>
                    </div>
                    <button type="submit" class="btn-valider">✅ Valider la commande (paiement à la livraison)</button>
                </form>
                
                <div class="separateur">
                    <span>OU</span>
                </div>
                
                <form action="/creer-paiement" method="POST">
                    <button type="submit" class="btn-paiement-ligne">
                        💳 Payer en ligne (Carte bancaire)
                    </button>
                </form>
                
                <!-- ========== SECTION WAVE ========== -->
                <div class="wave-section">
                    <div class="wave-info">
                        <img src="https://play-lh.googleusercontent.com/-Mp3XW7uhwn3KGQxUKGPoc4MbA5ti-3-q23TgoVi9ujBgHWW5n4IySvlG5Exwrxsjw=w240-h480-rw" alt="Wave" class="wave-logo" onerror="this.src='https://placehold.co/60x60?text=Wave'">
                        <h3>💚 Paiement Wave</h3>
                        <p>Effectuez votre paiement via Wave à ce numéro :</p>
                        <div class="wave-number">
                            <span>📞 <strong>07 48 41 52 86</strong></span>
                            <button type="button" onclick="copierNumero()" class="btn-copier">📋 Copier</button>
                        </div>
                        <p class="wave-instruction">Après paiement, entrez le numéro de transaction ci-dessous :</p>
                        <form action="/valider-commande-wave" method="POST">
                            <input type="text" name="transaction_id" placeholder="Numéro de transaction Wave" required>
                            <input type="tel" name="telephone" placeholder="📞 Votre numéro Wave" required>
                            <textarea name="adresse" placeholder="🏠 Votre adresse de livraison" rows="2" required></textarea>
                            <button type="submit" class="btn-wave">✅ Valider la commande (Wave)</button>
                        </form>
                    </div>
                </div>
            </div>
            
        <% } %>
    </div>
    
    <div class="footer">
        <div class="footer-container">
            <div class="footer-section">
                <h3>🍕 TONKPIRESTO</h3>
                <p>LE GOUT DES SOMMETS, LIVRE CHEZ VOUS</p>
                <p>Votre service de livraison de repas préféré.</p>
            </div>
            <div class="footer-section">
                <h3>📞 CONTACT</h3>
                <p>📱 Téléphone : <a href="tel:+2250555594062">+225 05 55 59 40 62</a></p>
                <p>📧 Email : <a href="mailto:contact@tonkpiresto.com">contact@tonkpiresto.com</a></p>
                <p>🕒 Horaires : 11h00 - 22h00 (7j/7)</p>
            </div>
            <div class="footer-section">
                <h3>📍 ADRESSE</h3>
                <p>Abidjan, Côte d'Ivoire</p>
                <p>Livraison dans tout Abidjan</p>
                <div class="social-icons">
                    <a href="#" style="color: white;">📘</a>
                    <a href="#" style="color: white;">📸</a>
                    <a href="#" style="color: white;">🐦</a>
                    <a href="#" style="color: white;">💬</a>
                </div>
            </div>
        </div>
        <div class="copyright">
            &copy; 2024 TONKPIRESTO - Tous droits réservés | Site réalisé avec 🍕 pour vous servir
        </div>
    </div>
    
    <script>
        function copierNumero() {
            const numero = '0748415286';
            navigator.clipboard.writeText(numero);
            alert('✅ Numéro copié : ' + numero);
        }
    </script>
</body>
</html>